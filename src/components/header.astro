---
import { Icon } from "astro-icon/components";
import { NavigationLinks, SecondaryNavigationLinks, Logo } from "../config";
import Theme from "../components/theme.astro";
import Img from "../components/img.astro";
---

<div class="relative h-16 w-full">
  <nav
    x-data="{ isOpen: false }"
    @keydown.escape.window="isOpen = false"
    class="dark:bg-gray-800"
  >
    <div
      class="fixed inset-x-0 z-50 px-2 sm:px-6 lg:px-8 bg-white dark:bg-gray-800 border-b-2 border-purple-300 dark:border-purple-600"
    >
      <div class="relative flex items-center justify-between h-16">
        <div class="absolute inset-y-0 left-0 flex items-center lg:hidden">
          <!-- Mobile menu button-->
          <button
            type="button"
            x-on:click="isOpen = !isOpen"
            class="inline-flex items-center justify-center p-2 rounded-md text-purple-600 hover:text-pink-600 hover:bg-purple-200 dark:text-purple-300 dark:hover:text-pink-300 dark:hover:bg-purple-800 dark:focus:ring-purple-800 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-purple-300"
            aria-controls="mobile-menu"
            aria-expanded="false"
          >
            <span class="sr-only">Open main menu</span>
            <Icon
              x-bind:class="{'hidden': isOpen, 'block': !isOpen }"
              class="block h-6 w-6"
              aria-hidden="true"
              name="mdi:menu"
            />
            <Icon
              x-bind:class="{'block': isOpen, 'hidden': !isOpen }"
              class="hidden h-6 w-6"
              aria-hidden="true"
              name="mdi:close"
            />
          </button>
        </div>
        <div
          class="flex-1 flex items-center justify-center lg:items-stretch lg:justify-start"
        >
          <div class="flex-shrink-0 flex items-center">
            <Img class="block h-8 w-8 dark:bg-gray-100" src={Logo} alt="Logo" />
          </div>
          <div class="hidden lg:block lg:ml-6">
            <div class="flex space-x-4">
              {
                NavigationLinks.map((item) => (
                  <a
                    href={import.meta.env.BASE_URL + item.href}
                    class={
                      (item.href.length > 0 &&
                      Astro.url.toString().includes(item.href)
                        ? "bg-purple-200 text-pink-600 dark:bg-purple-800 dark:text-pink-300"
                        : "text-purple-600 hover:bg-purple-200 hover:text-pink-600 dark:text-purple-200 dark:hover:bg-purple-800 dark:hover:text-pink-300") +
                      " px-2 py-2 rounded-md text-lg font-medium"
                    }
                    aria-current={
                      item.href.length > 0 &&
                      Astro.url.toString().includes(item.href)
                        ? "page"
                        : undefined
                    }
                  >
                    {item.name}
                  </a>
                ))
              }
              <div class="relative" x-data="{ showMore: false }">
                <button
                  type="button"
                  x-on:click="showMore = !showMore"
                  @keydown.escape.window="showMore = false"
                  x-bind:aria-expanded="showMore"
                  aria-controls="more-menu"
                  class="inline-flex items-center px-2 py-2 rounded-md text-lg font-medium text-purple-600 hover:bg-purple-200 hover:text-pink-600 dark:text-purple-200 dark:hover:bg-purple-800 dark:hover:text-pink-300"
                >
                  More
                  <Icon class="w-4 h-4 ml-1" name="mdi:chevron-down" />
                </button>
                <div
                  id="more-menu"
                  x-show="showMore"
                  x-cloak
                  x-on:click.outside="showMore = false"
                  x-transition
                  class="absolute left-0 mt-2 w-56 rounded-md shadow-lg bg-white dark:bg-gray-800 border border-purple-200 dark:border-purple-700 py-2"
                >
                  {
                    SecondaryNavigationLinks.map((item) => (
                      <a
                        href={import.meta.env.BASE_URL + item.href}
                        class={
                          (Astro.url.toString().includes(item.href)
                            ? "bg-purple-100 text-pink-600 dark:bg-purple-900 dark:text-pink-300"
                            : "text-purple-700 hover:bg-purple-100 hover:text-pink-600 dark:text-purple-200 dark:hover:bg-purple-900 dark:hover:text-pink-300") +
                          " block px-4 py-2 text-sm font-semibold"
                        }
                        aria-current={
                          Astro.url.toString().includes(item.href)
                            ? "page"
                            : undefined
                        }
                      >
                        {item.name}
                      </a>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </div>
        <div
          class="absolute inset-y-0 right-0 flex items-center pr-2 sm:static sm:inset-auto sm:ml-6 sm:pr-0"
        >
          <Theme />

          <!-- Right nav -->
        </div>
      </div>
    </div>

    <!-- Mobile menu, show/hide based on menu state. -->
    <div
      x-show="isOpen"
      x-cloak
      x-transition:enter="transition ease-out duration-100 transform"
      x-transition:enter-start="opacity-0 scale-95"
      x-transition:enter-end="opacity-100 scale-100"
      x-transition:leave="transition ease-in duration-75 transform"
      x-transition:leave-start="opacity-100 scale-100"
      x-transition:leave-end="opacity-0 scale-95"
      class="fixed top-16 inset-x-0 z-50 lg:hidden"
      id="mobile-menu"
    >
      <div
        class="px-4 py-3 bg-gray-100 dark:bg-gray-800 border-purple-300 dark:border-purple-600 border-t-2 border-b-2 max-h-[calc(100vh-4rem)] overflow-y-auto"
      >
        <div class="grid grid-cols-1 gap-2">
          {
            NavigationLinks.map((item) => (
              <a
                href={import.meta.env.BASE_URL + item.href}
                x-on:click="isOpen = false"
                class:list={[
                  item.href.length > 0 &&
                  Astro.url.toString().includes(item.href)
                    ? "bg-purple-200 text-pink-600 dark:bg-purple-800 dark:text-pink-300"
                    : "text-purple-700 hover:bg-purple-200 hover:text-pink-600 dark:text-purple-200 dark:hover:bg-purple-800 dark:hover:text-pink-300",
                  "block rounded-md px-3 py-2 text-base font-semibold",
                ]}
                aria-current={
                  item.href.length > 0 &&
                  Astro.url.toString().includes(item.href)
                    ? "page"
                    : undefined
                }
              >
                {item.name}
              </a>
            ))
          }
          <div
            class="mt-2 pt-2 border-t border-purple-200 dark:border-purple-700"
          >
            <p
              class="px-3 py-1 text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400"
            >
              More
            </p>
            {
              SecondaryNavigationLinks.map((item) => (
                <a
                  href={import.meta.env.BASE_URL + item.href}
                  x-on:click="isOpen = false"
                  class:list={[
                    Astro.url.toString().includes(item.href)
                      ? "bg-purple-200 text-pink-600 dark:bg-purple-800 dark:text-pink-300"
                      : "text-purple-700 hover:bg-purple-200 hover:text-pink-600 dark:text-purple-200 dark:hover:bg-purple-800 dark:hover:text-pink-300",
                    "block rounded-md px-3 py-2 text-base font-semibold",
                  ]}
                  aria-current={
                    Astro.url.toString().includes(item.href)
                      ? "page"
                      : undefined
                  }
                >
                  {item.name}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </nav>
</div>
