---
import type { CollectionEntry } from "astro:content";

export interface Props {
  base: string;
  prev: CollectionEntry<"blog"> | CollectionEntry<"doc"> | undefined;
  next: CollectionEntry<"blog"> | CollectionEntry<"doc"> | undefined;
}

const { base, prev, next } = Astro.props;
---

<dl
  class="mt-12 mx-auto max-w-screen-lg px-4 lg:px-0 flex flex-col md:flex-row gap-6 border-t border-purple-300 pt-6 dark:border-purple-700"
>
  {
    prev && (
      <div class="w-full md:w-1/2 text-left min-w-0">
        <dt class="font-display text-sm font-medium text-gray-800 dark:text-gray-200">
          Prev
        </dt>
        <dd class="mt-1">
          <a
            class="inline-block rounded px-1 text-base font-semibold text-purple-600 hover:text-pink-700 hover:bg-purple-100 dark:text-purple-300 dark:hover:text-white dark:hover:bg-purple-700 break-words"
            href={base + prev.id}
          >
            <span aria-hidden="true">←</span>
            {prev.data.title}
          </a>
        </dd>
      </div>
    )
  }
  {
    next && (
      <div class="w-full md:w-1/2 text-left md:text-right min-w-0 md:ml-auto">
        <dt class="font-display text-sm font-medium text-gray-800 dark:text-gray-200">
          Next
        </dt>
        <dd class="mt-1">
          <a
            class="inline-block rounded px-1 text-base font-semibold text-purple-600 hover:text-pink-700 hover:bg-purple-100 dark:text-purple-300 dark:hover:text-white dark:hover:bg-purple-700 break-words"
            href={base + next.id}
          >
            {next.data.title}
            <span aria-hidden="true">→</span>
          </a>
        </dd>
      </div>
    )
  }
</dl>
