---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import Tags from "./tags.astro";

export interface Props {
  podcast: CollectionEntry<"podcasts">;
}

const { podcast } = Astro.props;
---

<section class="p-4 md:w-1/2 lg:w-1/3">
  <div
    class="h-full border-1 border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-800 rounded-lg shadow-xl overflow-hidden p-6"
  >
    <div
      class="inline-flex items-center mb-3 px-2 py-1 rounded bg-purple-100 dark:bg-purple-900 text-purple-700 dark:text-purple-200 text-xs font-semibold"
    >
      <Icon class="w-4 h-4 mr-1" name="mdi:microphone" />
      Podcast and Live Interviews
    </div>

    <h3
      class="title-font text-xl font-bold text-purple-600 dark:text-purple-300"
    >
      {podcast.data.title}
    </h3>

    <div
      class="mt-3 flex items-center flex-wrap gap-3 text-xs text-gray-500 dark:text-gray-400"
    >
      {
        podcast.data.episodeNumber && (
          <span class="inline-flex items-center">
            <Icon class="w-4 h-4 mr-1" name="mdi:numeric" />
            Episode {podcast.data.episodeNumber}
          </span>
        )
      }
      <span class="inline-flex items-center">
        <Icon class="w-4 h-4 mr-1" name="mdi:calendar" />
        {podcast.data.publishDate.toDateString()}
      </span>
      {
        podcast.data.platform && (
          <span class="inline-flex items-center">
            <Icon class="w-4 h-4 mr-1" name="mdi:podcast" />
            {podcast.data.platform}
          </span>
        )
      }
    </div>

    <p class="mt-3 text-sm text-gray-600 dark:text-gray-300">
      {podcast.data.description}
    </p>

    {
      podcast.data.guests && podcast.data.guests.length > 0 && (
        <p class="mt-3 text-sm text-gray-600 dark:text-gray-300">
          <span class="font-semibold">Guests:</span>{" "}
          {podcast.data.guests.join(", ")}
        </p>
      )
    }

    <div class="mt-5 flex flex-wrap items-center gap-3">
      {
        podcast.data.audioUrl && (
          <a
            href={podcast.data.audioUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 rounded-md bg-purple-600 hover:bg-pink-600 text-white dark:bg-purple-300 dark:hover:bg-pink-300 dark:text-black font-bold text-base"
          >
            <Icon class="w-5 h-5 mr-2" name="mdi:headphones" />
            Listen Audio
          </a>
        )
      }
      {
        podcast.data.videoUrl && (
          <a
            href={podcast.data.videoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 rounded-md bg-purple-100 hover:bg-pink-200 text-purple-800 dark:bg-purple-900 dark:hover:bg-pink-900 dark:text-purple-100 font-bold text-base"
          >
            <Icon class="w-5 h-5 mr-2" name="mdi:video-outline" />
            Watch Video
          </a>
        )
      }
    </div>

    <Tags tags={podcast.data.tags} />
  </div>
</section>
