---
import type { ContributionDay } from "../lib/github";

export interface Props {
  contributions: ContributionDay[];
  totalContributions: number;
  profileUrl?: string;
}

const {
  contributions = [],
  totalContributions = 0,
  profileUrl = "https://github.com/santoshyadavdev",
} = Astro.props;

const sortedContributions = [...contributions].sort(
  (a, b) => new Date(a.date).getTime() - new Date(b.date).getTime(),
);

const weekMap = new Map<string, ContributionDay[]>();

sortedContributions.forEach((day) => {
  const currentDate = new Date(`${day.date}T00:00:00Z`);
  const weekStart = new Date(currentDate);
  weekStart.setUTCDate(currentDate.getUTCDate() - currentDate.getUTCDay());
  const weekKey = weekStart.toISOString().slice(0, 10);
  const week = weekMap.get(weekKey) ?? [];
  week.push(day);
  weekMap.set(weekKey, week);
});

const weekColumns = [...weekMap.entries()]
  .sort((a, b) => a[0].localeCompare(b[0]))
  .map(([, days]) => {
    const cells: Array<ContributionDay | null> = Array.from(
      { length: 7 },
      () => null,
    );

    days.forEach((day) => {
      const dayIndex = new Date(`${day.date}T00:00:00Z`).getUTCDay();
      cells[dayIndex] = day;
    });

    return cells;
  });

const levelClasses: Record<number, string> = {
  0: "bg-gray-100 dark:bg-gray-700",
  1: "bg-purple-100 dark:bg-purple-900",
  2: "bg-purple-300 dark:bg-purple-700",
  3: "bg-purple-600 dark:bg-purple-500",
  4: "bg-pink-600 dark:bg-pink-500",
};

const getLevelClass = (level: number) => levelClasses[level] ?? levelClasses[0];
---

{
  contributions.length > 0 && (
    <div class="bg-white dark:bg-gray-900">
      <div class="max-w-7xl mx-auto px-2 sm:px-6 lg:px-8">
        <div class="py-8 sm:py-12 lg:py-16 lg:max-w-none">
          <div class="flex flex-row items-center justify-between flex-wrap gap-2">
            <h2 class="text-2xl md:text-4xl font-extrabold text-purple-800 dark:text-purple-200">
              GitHub Contributions
            </h2>
            {profileUrl && (
              <a
                href={profileUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block px-3 py-2 rounded-md bg-purple-600 hover:bg-pink-600 text-white dark:bg-purple-300 dark:hover:bg-pink-300 dark:text-black font-bold text-sm md:text-base"
              >
                View Profile
              </a>
            )}
          </div>

          <p class="mt-3 text-base md:text-lg text-gray-700 dark:text-gray-200">
            Total contributions:{" "}
            <span class="font-bold">{totalContributions}</span>
          </p>

          <div class="mt-6 w-full overflow-x-auto">
            <div
              class="grid min-w-full gap-px sm:gap-0.5 md:gap-1"
              style={`grid-template-columns: repeat(${weekColumns.length}, minmax(4px, 1fr));`}
            >
              {weekColumns.map((week) => (
                <div class="grid grid-rows-7 gap-px sm:gap-0.5 md:gap-1">
                  {week.map((day) => (
                    <div
                      class={`h-2 w-full sm:h-2.5 md:h-3 rounded-[1px] md:rounded-sm ${
                        day ? getLevelClass(day.level) : getLevelClass(0)
                      } hover:opacity-90`}
                      title={
                        day ? `${day.count} contributions on ${day.date}` : ""
                      }
                    />
                  ))}
                </div>
              ))}
            </div>
          </div>

          <div class="mt-4 flex items-center justify-end gap-2 text-sm text-gray-600 dark:text-gray-300">
            <span>Less</span>
            {[0, 1, 2, 3, 4].map((level) => (
              <span class={`h-3 w-3 rounded-sm ${getLevelClass(level)}`} />
            ))}
            <span>More</span>
          </div>
        </div>
      </div>
    </div>
  )
}
