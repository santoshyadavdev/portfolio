---
import { Icon } from "astro-icon/components";
import { authorDetail, Frontmatter } from "../config";
import Categories from "../components/categories.astro";
import Tags from "../components/tags.astro";
import Img from "../components/img.astro";

export interface Props {
  frontmatter: Frontmatter;
}

const { frontmatter } = Astro.props;
---

<div class="my-4 md:mb-0 w-full max-w-screen-xl mx-auto">
  <div
    class="rounded-lg border border-purple-300/40 dark:border-purple-700/60 bg-gradient-to-br from-purple-50 to-white dark:from-gray-900 dark:to-gray-800 p-4 sm:p-6 md:p-8 shadow-xl"
  >
    <Categories categories={frontmatter.categories} />
    <h2
      class="text-2xl sm:text-3xl md:text-4xl font-bold text-purple-900 dark:text-purple-100 leading-tight break-words"
    >
      {frontmatter.title}
    </h2>
    <p
      class="text-base sm:text-lg md:text-xl font-medium italic text-purple-700 dark:text-purple-300 mt-1"
    >
      {frontmatter.description}
    </p>
    <span class="flex flex-wrap gap-3 mt-4 text-sm sm:text-base">
      {
        frontmatter.author && (
          <span class="flex items-center">
            <Img
              src={authorDetail(frontmatter.author).image}
              alt={frontmatter.author}
              class="h-8 w-8 sm:h-10 sm:w-10 rounded-full mr-2 object-cover"
            />
            <Icon
              class="w-5 h-5 sm:w-6 sm:h-6 mr-1 text-purple-700 dark:text-purple-300"
              name="mdi:user-circle"
            />
            <span class="font-semibold text-purple-800 dark:text-purple-200">
              {frontmatter.author}
            </span>
          </span>
        )
      }
      <span class="flex items-center">
        <Icon
          class="w-5 h-5 sm:w-6 sm:h-6 mr-1 text-purple-700 dark:text-purple-300"
          name="mdi:calendar"
        />
        <span class="font-semibold text-purple-800 dark:text-purple-200 ml-1">
          {
            new Date(frontmatter.publishDate).toLocaleDateString(undefined, {
              year: "numeric",
              month: "short",
              day: "numeric",
            })
          }
        </span>
      </span>
      <span class="flex items-center">
        <Icon
          class="w-5 h-5 sm:w-6 sm:h-6 mr-1 text-purple-700 dark:text-purple-300"
          name="mdi:clock"
        />
        <span class="font-semibold text-purple-800 dark:text-purple-200 ml-1">
          {frontmatter.minutesRead}
        </span>
      </span>
    </span>
    <Tags tags={frontmatter.tags} />
  </div>
</div>
