---
import { Icon } from "astro-icon/components";
import type { UpcomingStream } from "../lib/youtube";

export interface Props {
  stream: UpcomingStream;
}

const { stream } = Astro.props;

const scheduledDate = new Date(stream.scheduledStartTime);
const formattedScheduledTime = Number.isNaN(scheduledDate.getTime())
  ? stream.scheduledStartTime
  : scheduledDate.toLocaleString(undefined, {
      year: "numeric",
      month: "short",
      day: "numeric",
      hour: "numeric",
      minute: "2-digit",
      timeZoneName: "short",
    });

const ctaLabel = stream.isLive ? "Watch Live" : "Set Reminder";
const statusText = stream.isLive ? "Live Now" : "Upcoming";
---

<section class="p-4 md:w-1/2 lg:w-1/3">
  <article
    class="h-full border border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-800 rounded-lg shadow-xl overflow-hidden p-2 hover:shadow-2xl"
    aria-label={`${statusText}: ${stream.title}`}
  >
    <a href={stream.url} target="_blank" rel="noopener noreferrer">
      <img
        src={stream.thumbnail}
        alt={stream.title}
        loading="lazy"
        class="relative w-full h-56 bg-purple-100 dark:bg-purple-800 rounded-lg overflow-hidden object-center object-cover"
      />
    </a>

    <div class="p-4">
      <div
        class="inline-flex items-center px-2 py-1 rounded bg-purple-100 dark:bg-purple-900 text-purple-700 dark:text-purple-200 text-xs font-semibold"
      >
        <span class="relative mr-2 flex h-2.5 w-2.5" aria-hidden="true">
          {
            stream.isLive && (
              <span class="absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75 animate-ping" />
            )
          }
          <span
            class={`relative inline-flex rounded-full h-2.5 w-2.5 ${stream.isLive ? "bg-red-500" : "bg-purple-500"}`}
          ></span>
        </span>
        {statusText}
      </div>

      <a href={stream.url} target="_blank" rel="noopener noreferrer">
        <h3
          class="mt-3 title-font text-xl font-bold text-purple-600 hover:text-pink-600 dark:text-purple-300 dark:hover:text-pink-300"
        >
          {stream.title}
        </h3>
      </a>

      <p
        class="mt-3 flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300"
      >
        <Icon class="w-4 h-4" name="mdi:calendar-clock" />
        <span>{formattedScheduledTime}</span>
      </p>

      <p class="mt-3 text-sm text-gray-600 dark:text-gray-300">
        {stream.description}
      </p>

      <a
        href={stream.url}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-5 inline-flex items-center px-4 py-2 rounded-md bg-purple-600 hover:bg-pink-600 text-white dark:bg-purple-300 dark:hover:bg-pink-300 dark:text-black font-bold text-base"
        aria-label={`${ctaLabel}: ${stream.title}`}
      >
        <Icon
          class="w-5 h-5 mr-2"
          name={stream.isLive ? "logos:youtube-icon" : "mdi:bell-ring-outline"}
        />
        {ctaLabel}
      </a>
    </div>
  </article>
</section>
