---
import { getCollection } from "astro:content";
import type { Frontmatter } from "../config";
import { SiteMetadata } from "../config";
import Base from "../layouts/base.astro";
import PageHero from "../components/pagehero.astro";
import TalkCard from "../components/talkcard.astro";
import VideoCard from "../components/videocard.astro";
import { getPlaylistVideos, YOUTUBE_TALKS_PLAYLIST_ID } from "../lib/youtube";

const frontmatter: Frontmatter = {
  title: "Talks",
  description: "Conference talks, meetups, and sessions.",
  coverSVG: "../images/svg/undraw/santosh_yadav.svg",
  socialImage: "../images/santosh-og.jpg",
  publishDate: SiteMetadata.buildTime,
};

const [talksCollection, playlistVideos] = await Promise.all([
  getCollection("talks"),
  getPlaylistVideos(YOUTUBE_TALKS_PLAYLIST_ID),
]);

const talks = talksCollection
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => +b.data.eventDate - +a.data.eventDate);

const talkRecordings = [...playlistVideos].sort(
  (a, b) =>
    new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime(),
);
---

<Base frontmatter={frontmatter}>
  <header>
    <PageHero
      title={frontmatter.title}
      description={frontmatter.description}
      coverSVG={frontmatter.coverSVG}
      socialImage={frontmatter.socialImage}
    />
  </header>

  <main
    class="mt-8 bg-white dark:bg-gray-900"
    data-pagefind-body
    data-pagefind-meta={`title:${frontmatter.title}`}
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto pb-16 sm:pb-24 lg:pb-32 lg:max-w-none">
        <h2
          class="text-2xl md:text-4xl font-extrabold text-purple-800 dark:text-purple-200"
        >
          Conference Talks
        </h2>
        {
          talks.length > 0 ? (
            <div class="mt-6 flex flex-wrap -mx-4">
              {talks.map((talk) => (
                <TalkCard talk={talk} />
              ))}
            </div>
          ) : (
            <div class="mt-6 text-center py-12">
              <p class="text-xl text-gray-600 dark:text-gray-400">
                No talks to display yet.
              </p>
            </div>
          )
        }

        <section class="mt-12">
          <h2
            class="text-2xl md:text-4xl font-extrabold text-purple-800 dark:text-purple-200"
          >
            All Talk Recordings
          </h2>
          {
            talkRecordings.length > 0 ? (
              <div class="mt-6 flex flex-wrap -mx-4">
                {talkRecordings.map((video) => (
                  <VideoCard video={video} />
                ))}
              </div>
            ) : (
              <div class="mt-6 text-center py-12">
                <p class="text-xl text-gray-600 dark:text-gray-400">
                  No talk recordings available at this time.
                </p>
              </div>
            )
          }
        </section>
      </div>
    </div>
  </main>
</Base>
