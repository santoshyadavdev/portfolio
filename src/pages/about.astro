---
import Base from "../layouts/base.astro";
import Timeline from "../components/timeline.astro";

const frontmatter = {
  title: "My Journey",
  description:
    "From the slums of Mumbai to becoming a recognized developer advocate, GDE, and GitHub Star - this is my journey.",
  publishDate: new Date("2022-08-08"),
  coverSVG: "../images/svg/undraw/santosh_yadav.svg",
  socialImage: "../images/santosh-og.jpg",
};
---

<Base frontmatter={frontmatter}>
  <main class="dark:bg-gray-900">
    <!-- Full Page Timeline -->
    <Timeline />

    <!-- Read Full Story CTA -->
    <section
      class="py-16 bg-gradient-to-b from-gray-50 to-white dark:from-gray-900 dark:to-gray-800"
    >
      <div class="max-w-4xl mx-auto px-4 text-center">
        <p class="text-lg text-gray-600 dark:text-gray-300 mb-8">
          Want to read the complete story with all the details?
        </p>
        <a
          href="https://www.freecodecamp.org/news/my-journey-into-tech-from-slums-of-mumbai-to-my-own-apartment/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-8 py-4 text-lg font-bold text-white bg-gradient-to-r from-purple-600 to-pink-500 rounded-full shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 group"
        >
          Read My Full Story on freeCodeCamp
          <svg
            class="w-5 h-5 ml-3 transition-transform group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </section>
  </main>
</Base>
