---
import { getCollection } from "astro:content";
import type { Frontmatter } from "../config";
import { SiteMetadata } from "../config";
import Base from "../layouts/base.astro";
import Hero from "../components/hero.astro";
import LatestAwards from "../components/latestawards.astro";
import ContributionsGraph from "../components/contributionsgraph.astro";
import LatestTalksPodcasts from "../components/latesttalkspodcasts.astro";
import UpcomingLiveStreams from "../components/upcominglivestreams.astro";
import VideoCard from "../components/videocard.astro";
import LatestArticles from "../components/latestarticles.astro";
import LatestBluesky from "../components/latestbluesky.astro";
import LatestSponsors from "../components/latestsponsors.astro";
import LatestTestimonials from "../components/latesttestimonials.astro";
import Newsletter from "../components/newsletter.astro";
import { getBlueskyPosts } from "../lib/bluesky";
import { getGitHubContributions, getMySponsors } from "../lib/github";
import { getTestimonials } from "../lib/testimonials";
import {
  getChannelVideos,
  getPlaylistVideos,
  getUpcomingStreams,
  YOUTUBE_TALKS_PLAYLIST_ID,
} from "../lib/youtube";

const frontmatter: Frontmatter = {
  title: SiteMetadata.title,
  description: SiteMetadata.description,
  coverSVG: "../images/svg/undraw/santosh_yadav.svg",
  socialImage: "../images/santosh-og.jpg",
  publishDate: SiteMetadata.buildTime,
};

const [posts, talks, podcastEntries] = await Promise.all([
  getCollection("blog"),
  getCollection("talks"),
  getCollection("podcasts"),
]);

const latestPosts = posts
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate)
  .filter((p) => !p.data.draft);

const latestTalk = talks
  .filter((talk) => !talk.data.draft)
  .sort((a, b) => +b.data.eventDate - +a.data.eventDate)[0];

const latestHostedPodcast = podcastEntries
  .filter((podcast) => !podcast.data.draft && podcast.data.hostSlug)
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate)[0];

const latestGuestPodcast = podcastEntries
  .filter((podcast) => !podcast.data.draft && podcast.data.guestSlug)
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate)[0];

const featuredPodcasts = [latestHostedPodcast, latestGuestPodcast]
  .filter((podcast): podcast is NonNullable<typeof podcast> => Boolean(podcast))
  .filter(
    (podcast, index, list) =>
      list.findIndex((candidate) => candidate.id === podcast.id) === index,
  );

const [blueskyPosts, sponsors, contributions, testimonials, upcomingStreams] =
  await Promise.all([
    getBlueskyPosts(),
    getMySponsors(),
    getGitHubContributions(),
    getTestimonials(),
    getUpcomingStreams(),
  ]);

const fallbackRecentVideos =
  upcomingStreams.length === 0 ? await getChannelVideos(3) : [];

const latestPlaylistVideo = !latestTalk
  ? (await getPlaylistVideos(YOUTUBE_TALKS_PLAYLIST_ID, 1))[0]
  : undefined;
---

<Base frontmatter={frontmatter}>
  <Hero />
  <LatestAwards />
  <ContributionsGraph
    contributions={contributions.days}
    totalContributions={contributions.totalContributions}
  />
  <LatestArticles posts={latestPosts} />
  <LatestTalksPodcasts
    talk={latestTalk}
    podcasts={featuredPodcasts}
    latestVideo={latestPlaylistVideo}
  />
  {
    upcomingStreams.length > 0 ? (
      <UpcomingLiveStreams streams={upcomingStreams} />
    ) : (
      fallbackRecentVideos.length > 0 && (
        <div class="bg-white dark:bg-gray-900">
          <div class="max-w-7xl mx-auto px-2 sm:px-6 lg:px-8">
            <div class="py-8 sm:py-12 lg:py-16 lg:max-w-none">
              <div class="flex flex-col gap-3">
                <h2 class="text-2xl md:text-4xl font-extrabold text-purple-800 dark:text-purple-200">
                  Recent Videos
                </h2>
                <div>
                  <a
                    href={import.meta.env.BASE_URL + "videos"}
                    class="inline-flex items-center px-4 py-2 rounded-md text-purple-800 bg-purple-100 hover:bg-pink-200 dark:text-purple-100 dark:bg-purple-900 dark:hover:bg-pink-900 font-bold text-base"
                  >
                    View All Videos
                  </a>
                </div>
              </div>

              <div class="mt-6 flex flex-wrap -mx-4">
                {fallbackRecentVideos.map((video) => (
                  <VideoCard video={video} />
                ))}
              </div>
            </div>
          </div>
        </div>
      )
    )
  }
  <LatestTestimonials testimonials={testimonials.slice(0, 3)} />
  <LatestBluesky posts={blueskyPosts} />
  <LatestSponsors sponsors={sponsors} />
</Base>
