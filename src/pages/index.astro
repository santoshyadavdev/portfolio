---
import { getCollection } from "astro:content";
import type { Frontmatter } from "../config";
import { SiteMetadata } from "../config";
import Base from "../layouts/base.astro";
import Hero from "../components/hero.astro";
import LatestAwards from "../components/latestawards.astro";
import LatestTalksPodcasts from "../components/latesttalkspodcasts.astro";
import LatestArticles from "../components/latestarticles.astro";
import LatestTestimonials from "../components/latesttestimonials.astro";
import ProjectCard from "../components/projectcard.astro";
import { getTestimonials } from "../lib/testimonials";
import { getPlaylistVideos, YOUTUBE_TALKS_PLAYLIST_ID } from "../lib/youtube";

const frontmatter: Frontmatter = {
  title: SiteMetadata.title,
  description: SiteMetadata.description,
  coverSVG: "../images/svg/undraw/santosh_yadav.svg",
  socialImage: "../images/santosh-og.jpg",
  publishDate: SiteMetadata.buildTime,
};

const [posts, talks, podcastEntries, projectEntries] = await Promise.all([
  getCollection("blog"),
  getCollection("talks"),
  getCollection("podcasts"),
  getCollection("projects"),
]);

const latestPosts = posts
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate)
  .filter((p) => !p.data.draft);

const latestTalk = talks
  .filter((talk) => !talk.data.draft)
  .sort((a, b) => +b.data.eventDate - +a.data.eventDate)[0];

const latestHostedPodcast = podcastEntries
  .filter((podcast) => !podcast.data.draft && podcast.data.hostSlug)
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate)[0];

const latestGuestPodcast = podcastEntries
  .filter((podcast) => !podcast.data.draft && podcast.data.guestSlug)
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate)[0];

const featuredPodcasts = [latestHostedPodcast, latestGuestPodcast]
  .filter((podcast): podcast is NonNullable<typeof podcast> => Boolean(podcast))
  .filter(
    (podcast, index, list) =>
      list.findIndex((candidate) => candidate.id === podcast.id) === index,
  );

const featuredProjects = projectEntries
  .filter((entry) => !entry.data.draft)
  .sort(
    (a, b) =>
      +(b.data.publishDate ?? new Date(0)) -
      +(a.data.publishDate ?? new Date(0)),
  )
  .slice(0, 3);

const testimonials = await getTestimonials();

const latestPlaylistVideo = !latestTalk
  ? (await getPlaylistVideos(YOUTUBE_TALKS_PLAYLIST_ID, 1))[0]
  : undefined;
---

<Base frontmatter={frontmatter}>
  <Hero />

  {
    featuredProjects.length > 0 && (
      <div class="bg-white dark:bg-gray-900">
        <div class="max-w-7xl mx-auto px-2 sm:px-6 lg:px-8">
          <div class="py-8 sm:py-12 lg:py-16 lg:max-w-none">
            <div class="flex flex-row flex-wrap items-center gap-2">
              <h2 class="text-2xl md:text-4xl font-extrabold text-purple-800 dark:text-purple-200">
                Featured Projects
              </h2>
              <a
                href={import.meta.env.BASE_URL + "projects"}
                class="inline-block px-2 py-2 md:px-6 md:py-3 rounded-md bg-purple-600 hover:bg-pink-600 text-white dark:bg-purple-300 dark:hover:bg-pink-300 dark:text-black font-bold text-base md:text-lg"
              >
                View All Projects
              </a>
            </div>
            <div class="mt-6 flex flex-wrap -mx-4">
              {featuredProjects.map((project) => (
                <ProjectCard project={project} />
              ))}
            </div>
          </div>
        </div>
      </div>
    )
  }

  <LatestArticles posts={latestPosts} />
  <LatestTalksPodcasts
    talk={latestTalk}
    podcasts={featuredPodcasts}
    latestVideo={latestPlaylistVideo}
  />
  <LatestAwards />
  <LatestTestimonials testimonials={testimonials.slice(0, 3)} />
</Base>
