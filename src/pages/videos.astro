---
import type { Frontmatter } from "../config";
import { SiteMetadata } from "../config";
import Base from "../layouts/base.astro";
import PageHero from "../components/pagehero.astro";
import VideoCard from "../components/videocard.astro";
import { getChannelVideos } from "../lib/youtube";

const frontmatter: Frontmatter = {
  title: "Videos",
  description: "Browse all videos from the TechTalksWithSantosh channel.",
  coverSVG: "../images/svg/undraw/santosh_yadav.svg",
  socialImage: "../images/santosh-og.jpg",
  publishDate: SiteMetadata.buildTime,
};

const videos = await getChannelVideos(6);
---

<Base frontmatter={frontmatter}>
  <header>
    <PageHero
      title={frontmatter.title}
      description={frontmatter.description}
      coverSVG={frontmatter.coverSVG}
      socialImage={frontmatter.socialImage}
    />
  </header>

  <main
    class="mt-8 bg-white dark:bg-gray-900"
    data-pagefind-body
    data-pagefind-meta={`title:${frontmatter.title}`}
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto pb-16 sm:pb-24 lg:pb-32 lg:max-w-none">
        {
          videos.length > 0 ? (
            <div class="mt-6 flex flex-wrap -mx-4">
              {videos.map((video) => (
                <VideoCard video={video} />
              ))}
            </div>
          ) : (
            <div class="mt-6 text-center py-12">
              <p class="text-xl text-gray-600 dark:text-gray-400">
                No videos to display yet.
              </p>
            </div>
          )
        }
      </div>
    </div>
  </main>
</Base>
