---
import { getCollection } from "astro:content";
import type { Frontmatter } from "../config";
import { SiteMetadata } from "../config";
import Base from "../layouts/base.astro";
import PageHero from "../components/pagehero.astro";
import PodcastCard from "../components/podcastcard.astro";
import VideoCard from "../components/videocard.astro";
import {
  getPlaylistVideos,
  YOUTUBE_APPEARANCES_PLAYLIST_ID,
} from "../lib/youtube";

const frontmatter: Frontmatter = {
  title: "Appearances",
  description: "Podcast episodes where I appeared as a guest.",
  coverSVG: "../images/svg/undraw/santosh_yadav.svg",
  socialImage: "../images/santosh-og.jpg",
  publishDate: SiteMetadata.buildTime,
};

const [appearancesCollection, playlistVideos] = await Promise.all([
  getCollection("podcasts"),
  getPlaylistVideos(YOUTUBE_APPEARANCES_PLAYLIST_ID),
]);

const appearances = appearancesCollection
  .filter((entry) => !entry.data.draft && entry.data.guestSlug)
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate);

const videoAppearances = [...playlistVideos].sort(
  (a, b) =>
    new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime(),
);
---

<Base frontmatter={frontmatter}>
  <header>
    <PageHero
      title={frontmatter.title}
      description={frontmatter.description}
      coverSVG={frontmatter.coverSVG}
      socialImage={frontmatter.socialImage}
    />
  </header>

  <main
    class="mt-8 bg-white dark:bg-gray-900"
    data-pagefind-body
    data-pagefind-meta={`title:${frontmatter.title}`}
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto pb-16 sm:pb-24 lg:pb-32 lg:max-w-none">
        <h2
          class="text-2xl md:text-4xl font-extrabold text-purple-800 dark:text-purple-200"
        >
          Podcast Appearances
        </h2>
        {
          appearances.length > 0 ? (
            <div class="mt-6 flex flex-wrap -mx-4">
              {appearances.map((podcast) => (
                <PodcastCard podcast={podcast} />
              ))}
            </div>
          ) : (
            <div class="mt-6 text-center py-12">
              <p class="text-xl text-gray-600 dark:text-gray-400">
                No guest appearances to display yet.
              </p>
            </div>
          )
        }

        <section class="mt-12">
          <h2
            class="text-2xl md:text-4xl font-extrabold text-purple-800 dark:text-purple-200"
          >
            Video Appearances
          </h2>
          {
            videoAppearances.length > 0 ? (
              <div class="mt-6 flex flex-wrap -mx-4">
                {videoAppearances.map((video) => (
                  <VideoCard video={video} />
                ))}
              </div>
            ) : (
              <div class="mt-6 text-center py-12">
                <p class="text-xl text-gray-600 dark:text-gray-400">
                  No video appearances available at this time.
                </p>
              </div>
            )
          }
        </section>
      </div>
    </div>
  </main>
</Base>
